---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CyberpunkBackground from '../../components/music/CyberpunkBackground.astro';
import PlatformSelector from '../../components/music/PlatformSelector.astro';
import SearchPanel from '../../components/music/SearchPanel.astro';
import MusicHero from '../../components/music/MusicHero.astro';
import PlaylistMasonry from '../../components/music/PlaylistMasonry.astro';
import MusicSearchResults from '../../components/music/MusicSearchResults.astro';
import MiniPlayerBar from '../../components/music/MiniPlayerBar.astro';
import MusicAtmospherePanel from '../../components/music/MusicAtmospherePanel.astro';
import MusicNotePanel from '../../components/music/MusicNotePanel.astro';
import { musicPlaylistsZh, platformAccentMap } from '../../components/music/music-data';

const lang = 'zh' as const;
const defaultPlatform = 'netease' as const;
const featured = musicPlaylistsZh.find((item) => item.platform === defaultPlatform) ?? musicPlaylistsZh[0];
---

<BaseLayout title="音乐 | Wang Zhai" lang={lang}>
  <CyberpunkBackground lang={lang} />
  <div class="music-discovery-page" data-platform={defaultPlatform} data-lang={lang}>
    <MusicHero lang={lang} featured={featured} currentPlatform={defaultPlatform} />

    <div class="music-discovery-controls">
      <PlatformSelector lang={lang} currentServer={defaultPlatform} />
      <SearchPanel lang={lang} />
    </div>

    <div class="music-discovery-support-grid">
      <MusicAtmospherePanel lang={lang} />
      <MusicNotePanel lang={lang} />
    </div>

    <PlaylistMasonry playlists={musicPlaylistsZh} currentPlatform={defaultPlatform} lang={lang} />
    <MusicSearchResults lang={lang} />
    <MiniPlayerBar lang={lang} />
  </div>
</BaseLayout>

<script is:inline define:vars={{ lang, playlists: musicPlaylistsZh, platformAccentMap }}>
  const apiBase = "https://api.injahow.cn/meting/";
  let currentServer = "netease";
  let searchSeq = 0;

  const pageRoot = document.querySelector('.music-discovery-page');
  const resultsList = document.getElementById('search-results-list');
  const shuffleTrigger = document.getElementById('music-shuffle-trigger');
  const miniPlayerBar = document.getElementById('mini-player-bar');
  const miniPlayerCover = document.getElementById('mini-player-cover');
  const miniPlayerTitle = document.getElementById('mini-player-title');
  const miniPlayerArtist = document.getElementById('mini-player-artist');
  const miniPlayerLink = document.getElementById('mini-player-link');

  const texts = {
    empty: lang === 'zh' ? '输入关键词搜索歌曲' : 'Type to search songs',
    noResults: lang === 'zh' ? '没有搜索到结果' : 'No matching songs',
    unknownArtist: lang === 'zh' ? '未知歌手' : 'Unknown Artist',
    searching: lang === 'zh' ? '搜索中...' : 'Searching...',
    openSong: lang === 'zh' ? '打开详情' : 'Open Detail',
  };

  function applyPlatformState(platform) {
    currentServer = platform;
    pageRoot?.setAttribute('data-platform', platform);
    const target = playlists.find((item) => item.platform === platform) || playlists[0];
    const hero = document.querySelector('.music-hero');
    hero?.classList.remove('accent-kugou', 'accent-netease', 'accent-tencent');
    hero?.classList.add(`accent-${platform}`);

    document.querySelectorAll('.playlist-tile').forEach((tile) => {
      const isVisible = tile.getAttribute('data-platform') === platform;
      tile.toggleAttribute('hidden', !isVisible);
    });

    if (target) {
      const featuredLink = document.querySelector('.music-hero-featured');
      const featuredImg = document.querySelector('.music-hero-cover');
      const featuredTitle = document.querySelector('.music-hero-card-copy h2');
      const featuredDesc = document.querySelector('.music-hero-card-copy p');
      const featuredChip = document.querySelector('.music-hero-chip');
      const primaryLink = document.querySelector('.music-hero-primary');
      const href = `/${lang === 'en' ? 'en/' : ''}music/playlist/${target.platform}/${target.id}`;
      featuredLink?.setAttribute('href', href);
      primaryLink?.setAttribute('href', href);
      if (featuredImg instanceof HTMLImageElement) featuredImg.src = target.cover;
      if (featuredTitle) featuredTitle.textContent = target.name;
      if (featuredDesc) featuredDesc.textContent = target.description;
      if (featuredChip) featuredChip.textContent = target.mood;
    }
  }

  function renderResultItems(items) {
    if (!resultsList) return;
    if (items.length === 0) {
      resultsList.innerHTML = `<div class="music-search-empty">${texts.noResults}</div>`;
      return;
    }

    resultsList.innerHTML = items.map((item) => {
      const href = `/${lang === 'en' ? 'en/' : ''}music/song?id=${encodeURIComponent(item.id)}&platform=${encodeURIComponent(currentServer)}&title=${encodeURIComponent(item.title)}&artist=${encodeURIComponent(item.artist || '')}&cover=${encodeURIComponent(item.cover || '')}`;
      return `
        <a class="search-item-card" href="${href}" data-song-id="${item.id}">
          <img class="search-item-cover" src="${item.cover || ''}" alt="${item.title}" />
          <div class="search-item-main">
            <div class="search-item-title">${item.title}</div>
            <div class="search-item-artist">${item.artist || texts.unknownArtist}</div>
          </div>
          <span class="search-item-link">${texts.openSong}</span>
        </a>
      `;
    }).join('');
  }

  async function searchSongs(query) {
    if (!resultsList) return;
    const trimmed = query.trim();
    if (!trimmed) {
      resultsList.innerHTML = `<div class="music-search-empty">${texts.empty}</div>`;
      return;
    }

    const seq = ++searchSeq;
    resultsList.innerHTML = `<div class="music-search-empty">${texts.searching}</div>`;

    try {
      const url = `${apiBase}?server=${currentServer}&type=search&id=0&keyword=${encodeURIComponent(trimmed)}`;
      const response = await fetch(url);
      const data = await response.json();
      if (seq !== searchSeq) return;

      const items = Array.isArray(data)
        ? data.map((item) => ({
            id: item.id || item.songid || '',
            title: item.title || item.name || 'Unknown',
            artist: item.artist || item.author || '',
            cover: item.pic || item.cover || '',
          })).filter((item) => item.id)
        : [];

      renderResultItems(items);
    } catch {
      if (seq !== searchSeq) return;
      resultsList.innerHTML = `<div class="music-search-empty">${texts.noResults}</div>`;
    }
  }

  function updateMiniPlayer(detail) {
    if (!miniPlayerBar || !miniPlayerTitle || !miniPlayerArtist || !miniPlayerLink) return;
    miniPlayerBar.hidden = false;
    miniPlayerTitle.textContent = detail.title || '';
    miniPlayerArtist.textContent = detail.artist || '';
    if (miniPlayerCover instanceof HTMLImageElement) {
      miniPlayerCover.src = detail.cover || '';
      miniPlayerCover.alt = detail.title || '';
    }
    const href = detail.songId
      ? `/${lang === 'en' ? 'en/' : ''}music/song?id=${encodeURIComponent(detail.songId || '')}&platform=${encodeURIComponent(detail.server || currentServer)}&title=${encodeURIComponent(detail.title || '')}&artist=${encodeURIComponent(detail.artist || '')}&cover=${encodeURIComponent(detail.cover || '')}`
      : `/${lang === 'en' ? 'en/' : ''}music/playlist/${detail.server || currentServer}/${detail.playlistId || ''}`;
    miniPlayerLink.setAttribute('href', href);
  }

  window.addEventListener('platform-change', (e) => {
    if (!(e instanceof CustomEvent)) return;
    const nextServer = e.detail?.platform;
    if (nextServer === 'kugou' || nextServer === 'netease' || nextServer === 'tencent') {
      applyPlatformState(nextServer);
      const input = document.getElementById('music-search-input');
      if (input instanceof HTMLInputElement && input.value.trim()) {
        searchSongs(input.value);
      }
    }
  });

  window.addEventListener('music-search', (e) => {
    if (!(e instanceof CustomEvent)) return;
    searchSongs(String(e.detail?.query || ''));
  });

  window.addEventListener('player-track-changed', (e) => {
    if (!(e instanceof CustomEvent)) return;
    updateMiniPlayer(e.detail || {});
  });

  shuffleTrigger?.addEventListener('click', () => {
    const candidates = playlists.filter((item) => item.platform === currentServer);
    if (!candidates.length) return;
    const pick = candidates[Math.floor(Math.random() * candidates.length)];
    window.location.href = `/${lang === 'en' ? 'en/' : ''}music/playlist/${pick.platform}/${pick.id}`;
  });

  applyPlatformState(currentServer);
 </script>

<style>
  .music-discovery-page {
    /* Removed the opaque background so the cyberpunk background shows through */
    --page-bg: transparent;
    --page-orb-a: rgba(255, 94, 98, 0.16);
    --page-orb-b: rgba(89, 117, 255, 0.16);
    min-height: calc(100vh - 4rem);
    padding: 2rem 1.25rem 4rem;
    display: grid;
    gap: 1.25rem;
    background: var(--page-bg);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .music-discovery-page::before,
  .music-discovery-page::after {
    content: "";
    position: fixed;
    inset: auto;
    z-index: 0;
    pointer-events: none;
    filter: blur(70px);
    opacity: 0.9;
    mix-blend-mode: screen;
  }

  .music-discovery-page::before {
    top: 8rem;
    right: 8%;
    width: 260px;
    height: 260px;
    background: var(--page-orb-a);
    animation: musicOrbitA 14s ease-in-out infinite;
  }

  .music-discovery-page::after {
    bottom: 10%;
    left: 12%;
    width: 220px;
    height: 220px;
    background: var(--page-orb-b);
    animation: musicOrbitB 18s ease-in-out infinite;
  }

  .music-discovery-page[data-platform='kugou'] {
    --page-bg: transparent;
    --page-orb-a: rgba(102, 132, 255, 0.22);
    --page-orb-b: rgba(129, 73, 255, 0.18);
  }

  .music-discovery-page[data-platform='netease'] {
    --page-bg: transparent;
    --page-orb-a: rgba(255, 110, 92, 0.24);
    --page-orb-b: rgba(255, 176, 91, 0.16);
  }

  .music-discovery-page[data-platform='tencent'] {
    --page-bg: transparent;
    --page-orb-a: rgba(40, 232, 201, 0.2);
    --page-orb-b: rgba(76, 192, 255, 0.16);
  }

  .music-discovery-controls {
    display: grid;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .music-discovery-support-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  :global(.music-discovery-page > *) {
    position: relative;
    z-index: 1;
  }

  :global(.music-discovery-page .platform-selector),
  :global(.music-discovery-page .search-panel) {
    background: rgba(20, 25, 45, 0.4);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 24px;
    padding: 1rem 1.1rem;
  }

  :global(.music-discovery-page .platform-label),
  :global(.music-discovery-page .search-input),
  :global(.music-discovery-page .search-icon),
  :global(.music-discovery-page .platform-name),
  :global(.music-discovery-page .platform-icon) {
    color: #fff;
  }

  :global(.music-discovery-page .platform-buttons) {
    gap: 0.6rem;
  }

  :global(.music-discovery-page .platform-btn) {
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    padding: 0.7rem 1rem;
    background: rgba(255,255,255,0.04);
  }

  :global(.music-discovery-page .platform-btn.active) {
    background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(236,240,255,0.94));
    color: #0a1026 !important;
    border-color: rgba(255,255,255,0.4);
    box-shadow: 0 10px 24px rgba(0,0,0,0.18);
  }

  :global(.music-discovery-page .platform-btn.active .platform-name),
  :global(.music-discovery-page .platform-btn.active .platform-icon) {
    color: #0a1026 !important;
  }

  :global(.music-discovery-page .search-input-wrapper) {
    border: 0;
    background: transparent;
    padding: 0;
  }

  :global(.search-item-card) {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: #fff;
    padding: 0.9rem;
    border-radius: 20px;
    background: rgba(20, 25, 45, 0.4);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.12);
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  :global(.search-item-card:hover) {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.24);
    background: rgba(30, 35, 60, 0.6);
  }

  :global(.search-item-cover) {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    object-fit: cover;
  }

  :global(.search-item-main) {
    min-width: 0;
  }

  :global(.search-item-title) {
    font-family: var(--font-title);
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-item-artist) {
    margin-top: 0.25rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-item-link) {
    font-size: 0.75rem;
    padding: 0.42rem 0.62rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
  }

  @media (max-width: 720px) {
    .music-discovery-page {
      padding: 1rem 0.85rem 4rem;
    }

    .music-discovery-support-grid {
      grid-template-columns: 1fr;
    }

    :global(.search-item-card) {
      grid-template-columns: 56px 1fr;
    }

    :global(.search-item-link) {
      grid-column: 1 / -1;
      width: fit-content;
    }
  }

  @keyframes musicOrbitA {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-26px, 18px, 0) scale(1.12); }
  }

  @keyframes musicOrbitB {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(24px, -22px, 0) scale(1.08); }
  }
</style>
