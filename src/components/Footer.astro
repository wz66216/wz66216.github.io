---
import { t, type Lang, defaultLang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
---

<footer>
  <div class="chessboard-divider" role="separator"></div>
  <div class="content">
    <p>
      {t(lang, 'footer.copyright')}
      <span class="separator">|</span>
      <a href="/admin/index.html" class="admin-link">{t(lang, 'footer.admin')}</a>
    </p>
  </div>
</footer>

<style>
  footer {
    padding-bottom: var(--space-lg);
    background-color: var(--color-bg-white);
    color: var(--color-text-secondary);
  }

  /* Divider spacing */
  .chessboard-divider {
    margin-bottom: var(--space-lg);
  }

  .content {
    text-align: center;
    font-size: 0.85rem;
    font-family: var(--font-main);
  }

  .separator {
    margin: 0 var(--space-sm);
    color: var(--color-border);
  }

  .admin-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .admin-link:hover {
    color: var(--color-primary);
  }
</style>
