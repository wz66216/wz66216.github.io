---
import type { MusicPlatform } from './music-data';

interface Props {
  title: string;
  description: string;
  cover: string;
  platform: MusicPlatform;
  backHref: string;
  backLabel: string;
}

const { title, description, cover, platform, backHref, backLabel } = Astro.props;
---

<section class={`playlist-detail-hero accent-${platform}`}>
  <a class="playlist-detail-back" href={backHref}>{backLabel}</a>
  <div class="playlist-detail-cover-shell">
    <img src={cover} alt={title} class="playlist-detail-cover" />
  </div>
  <div class="playlist-detail-copy">
    <span class="playlist-detail-label">{platform}</span>
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
</section>

<style>
  .playlist-detail-hero {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
    align-items: end;
    padding: 1.5rem;
    border-radius: 30px;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, var(--hero-accent, rgba(255,90,90,0.32)), transparent 28%),
      linear-gradient(145deg, rgba(12, 14, 32, 0.94), rgba(20, 24, 46, 0.9));
    border: 1px solid rgba(255,255,255,0.09);
    box-shadow: 0 30px 80px rgba(0,0,0,0.28);
  }

  .playlist-detail-hero.accent-kugou { --hero-accent: rgba(93, 132, 255, 0.48); }
  .playlist-detail-hero.accent-netease { --hero-accent: rgba(255, 97, 97, 0.52); }
  .playlist-detail-hero.accent-tencent { --hero-accent: rgba(48, 219, 199, 0.42); }

  .playlist-detail-back {
    position: absolute;
    top: 1rem;
    left: 1rem;
    text-decoration: none;
    color: rgba(255,255,255,0.82);
    font-size: 0.86rem;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .playlist-detail-cover-shell {
    width: 190px;
    aspect-ratio: 1;
    padding: 4px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(255,255,255,0.45), rgba(255,255,255,0.05));
    margin-top: 2rem;
  }

  .playlist-detail-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    display: block;
  }

  .playlist-detail-copy {
    display: grid;
    gap: 0.65rem;
    color: #fff;
  }

  .playlist-detail-copy h1,
  .playlist-detail-copy p {
    margin: 0;
  }

  .playlist-detail-copy h1 {
    font-family: var(--font-title);
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 0.95;
  }

  .playlist-detail-copy p {
    max-width: 54ch;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
  }

  .playlist-detail-label {
    width: fit-content;
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
  }

  @media (max-width: 760px) {
    .playlist-detail-hero {
      grid-template-columns: 1fr;
      padding-top: 3.5rem;
    }

    .playlist-detail-cover-shell {
      width: 150px;
    }
  }
</style>
