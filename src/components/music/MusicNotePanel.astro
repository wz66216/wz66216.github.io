---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;

const copy = lang === 'zh'
  ? {
      title: 'Listening Notes',
      text: '平台切换会改变整页的色温与节奏，但真正的重点始终是你最后停下来的那首歌。',
    }
  : {
      title: 'Listening Notes',
      text: 'Platform switching changes the page temperature and rhythm, but the real focus is always the song you finally stay with.',
    };
---

<section class="music-note-panel">
  <h2>{copy.title}</h2>
  <p>{copy.text}</p>
</section>

<style>
  .music-note-panel {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.68);
  }

  .music-note-panel h2,
  .music-note-panel p {
    margin: 0;
  }

  .music-note-panel h2 {
    font-family: var(--font-code);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.52);
  }

  .music-note-panel p {
    line-height: 1.65;
  }
</style>
