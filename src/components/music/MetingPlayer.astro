---
interface Props {
  server?: "netease" | "tencent" | "kugou" | "xiami" | "baidu";
  type?: "song" | "playlist" | "album" | "search" | "artist";
  id: string;
  theme?: string;
  fixed?: boolean;
  mini?: boolean;
  autoplay?: boolean;
  volume?: number;
  listFolded?: boolean;
  order?: "list" | "random";
  loop?: "all" | "one" | "none";
}

const {
  server = "kugou",
  type = "playlist",
  id,
  theme = "var(--color-accent, #00F0FF)", // Cyberpunk match
  fixed = true, // By default globally fixed on the corner
  mini = false,
  autoplay = false,
  volume = 0.7,
  listFolded = true,
  order = "list",
  loop = "all"
} = Astro.props;
---

<!-- Import APlayer CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.css" />

<!-- MetingJS requires APlayer as a dependency -->
<script is:inline src="https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.js"></script>

<!-- MetingJS wrapper that interprets server, type and id -->
<script is:inline src="https://cdn.jsdelivr.net/npm/meting@2/dist/Meting.min.js"></script>

<meting-js
  server={server}
  type={type}
  id={id}
  theme={theme}
  fixed={fixed ? "true" : "false"}
  mini={mini ? "true" : "false"}
  autoplay={autoplay ? "true" : "false"}
  volume={volume}
  list-folded={listFolded ? "true" : "false"}
  order={order}
  loop={loop}
></meting-js>

<style is:global>
  /* 
   * Cyberpunk / Dark Mode overriding for APlayer 
   * APlayer comes with a default light theme, we need to make it blend into our site 
   */
  .aplayer {
    background: var(--color-bg-white) !important;
    border: 1px solid var(--color-border);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5) !important;
    font-family: var(--font-main) !important;
  }
  
  [data-theme="cyberpunk"] .aplayer {
    border-radius: 0 !important;
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    box-shadow: 0 0 10px var(--color-border) !important;
  }

  .aplayer .aplayer-info .aplayer-music .aplayer-title {
    color: var(--color-text-primary) !important;
  }

  .aplayer .aplayer-info .aplayer-music .aplayer-author {
    color: var(--color-text-secondary) !important;
  }

  .aplayer .aplayer-list ol li {
    border-top: 1px solid var(--color-border) !important;
  }

  .aplayer .aplayer-list ol li:hover {
    background: var(--color-section-dark-bg) !important;
  }

  .aplayer .aplayer-list ol li.aplayer-list-light {
    background: var(--color-section-dark-bg) !important;
  }

  .aplayer .aplayer-list ol li .aplayer-list-title {
    color: var(--color-text-primary) !important;
  }

  .aplayer .aplayer-list ol li .aplayer-list-author {
    color: var(--color-text-secondary) !important;
  }
  
  .aplayer .aplayer-lrc p {
    color: var(--color-text-primary) !important;
  }
</style>
