---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;

const copy = lang === 'zh'
  ? {
      title: '今日听感',
      lines: ['低照度', '慢热', '适合阅读与夜行'],
      note: '选一张歌单，把页面当作一小块临时的听觉场景。',
    }
  : {
      title: 'Today\'s Atmosphere',
      lines: ['low light', 'slow burn', 'for reading and late walks'],
      note: 'Choose a playlist and treat this page like a temporary listening environment.',
    };
---

<section class="music-atmosphere-panel">
  <h2>{copy.title}</h2>
  <div class="music-atmosphere-tags">
    {copy.lines.map((line) => <span>{line}</span>)}
  </div>
  <p>{copy.note}</p>
</section>

<style>
  .music-atmosphere-panel {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.05)),
      repeating-linear-gradient(90deg, rgba(255,255,255,0.05) 0 10px, transparent 10px 20px);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.72);
    position: relative;
    overflow: hidden;
  }

  .music-atmosphere-panel::after {
    content: "";
    position: absolute;
    inset: auto -4% -10px -4%;
    height: 30px;
    background: repeating-linear-gradient(90deg, rgba(255,255,255,0.12) 0 8px, transparent 8px 16px);
    clip-path: polygon(0 66%, 12% 48%, 24% 70%, 36% 44%, 48% 64%, 60% 40%, 72% 66%, 84% 48%, 100% 68%, 100% 100%, 0 100%);
    opacity: 0.18;
  }

  .music-atmosphere-panel h2,
  .music-atmosphere-panel p {
    margin: 0;
  }

  .music-atmosphere-panel h2 {
    font-family: var(--font-title);
    font-size: 1rem;
    color: #fff;
  }

  .music-atmosphere-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .music-atmosphere-tags span {
    padding: 0.38rem 0.62rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.06);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.78);
  }

  .music-atmosphere-panel p {
    line-height: 1.6;
  }
</style>
