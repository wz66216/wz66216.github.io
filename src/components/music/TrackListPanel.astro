---
interface TrackItem {
  id: string;
  title: string;
  artist: string;
}

interface Props {
  title: string;
  tracks: TrackItem[];
  lang?: 'zh' | 'en';
  platform: 'kugou' | 'netease' | 'tencent';
}

const { title, tracks, lang = 'zh', platform } = Astro.props;
const openLabel = lang === 'zh' ? '打开歌曲' : 'Open Song';
---

<section class="track-list-panel">
  <div class="track-list-panel-head">
    <h2>{title}</h2>
  </div>
  <div class="track-list-panel-body">
    {tracks.map((track, index) => (
      <a class="track-list-item" href={`/${lang === 'en' ? 'en/' : ''}music/song?id=${encodeURIComponent(track.id)}&platform=${encodeURIComponent(platform)}&title=${encodeURIComponent(track.title)}&artist=${encodeURIComponent(track.artist)}`}>
        <span class="track-list-index">{String(index + 1).padStart(2, '0')}</span>
        <div class="track-list-copy">
          <strong>{track.title}</strong>
          <span>{track.artist}</span>
        </div>
        <span class="track-list-link">{openLabel}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .track-list-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.05)),
      repeating-linear-gradient(90deg, rgba(255,255,255,0.05) 0 12px, transparent 12px 24px);
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
    overflow: hidden;
  }

  .track-list-panel::after {
    content: "";
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: -8px;
    height: 42px;
    background: repeating-linear-gradient(90deg, rgba(255,255,255,0.12) 0 10px, transparent 10px 20px);
    clip-path: polygon(0 60%, 10% 42%, 20% 68%, 30% 46%, 40% 64%, 50% 38%, 60% 60%, 70% 40%, 80% 70%, 90% 50%, 100% 64%, 100% 100%, 0 100%);
    opacity: 0.28;
  }

  .track-list-panel-head h2 {
    margin: 0;
    font-family: var(--font-title);
    font-size: 1.1rem;
    color: #fff;
  }

  .track-list-panel-body {
    display: grid;
    gap: 0.55rem;
  }

  .track-list-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.8rem;
    align-items: center;
    text-decoration: none;
    color: #fff;
    padding: 0.8rem 0.9rem;
    border-radius: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .track-list-index {
    font-family: var(--font-code);
    color: rgba(255,255,255,0.5);
    min-width: 2.2rem;
  }

  .track-list-copy {
    min-width: 0;
    display: grid;
    gap: 0.15rem;
  }

  .track-list-copy strong,
  .track-list-copy span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .track-list-copy span {
    color: rgba(255,255,255,0.6);
    font-size: 0.82rem;
  }

  .track-list-link {
    font-size: 0.74rem;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.06);
  }

  @media (max-width: 640px) {
    .track-list-item {
      grid-template-columns: auto 1fr;
    }

    .track-list-link {
      grid-column: 1 / -1;
      width: fit-content;
    }
  }
</style>
