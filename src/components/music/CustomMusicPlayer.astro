---
interface Props {
  server?: "netease" | "tencent" | "kugou" | "xiami" | "baidu";
  type?: "song" | "playlist" | "album" | "search" | "artist";
  id: string;
}

const {
  server = "kugou",
  type = "playlist",
  id,
} = Astro.props;
---

<div id="custom-music-player" class="music-widget" data-server={server} data-type={type} data-id={id}>
  <div class="vinyl-record draggable" id="player-drag-handle" aria-label="Toggle Player">
    <div class="vinyl-center">
      <img id="track-cover" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" alt="Cover" />
    </div>
  </div>

  <div class="player-panel" id="player-panel">
    <div class="player-body">
      <div class="track-info">
        <div id="track-name" class="scrolling-text">Loading...</div>
        <div id="track-artist">Fetching data</div>
      </div>

      <div class="controls">
        <button id="btn-prev" aria-label="Previous">⏮</button>
        <button id="btn-play" aria-label="Play/Pause">▶</button>
        <button id="btn-next" aria-label="Next">⏭</button>
      </div>
    </div>

    <div class="progress-container" id="progress-container">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
  </div>

  <audio id="audio-element" preload="none"></audio>
</div>

<style>
  /* --- Global Styles for the Widget --- */
  .music-widget {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 9999;
    font-family: var(--font-main);
    display: flex;
    align-items: center; /* Center align instead of flex-end */
    gap: 0;
    user-select: none;
    height: 64px; /* Explicit height to prevent collapse */
  }

  /* --- Vinyl Record (Draggable) --- */
  .vinyl-record {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #111; /* Pure black for vinyl */
    border: 3px solid var(--color-border, #ccc);
    box-shadow: 4px 4px 0px var(--color-border, #ccc);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    position: relative;
    z-index: 10;
    transition: transform 0.2s ease, border-color 0.3s ease;
    animation: spin 8s linear infinite;
    animation-play-state: paused;
    box-sizing: border-box;
  }
  
  .vinyl-record:active {
    cursor: grabbing;
  }

  .vinyl-record.playing {
    animation-play-state: running;
  }

  /* Vinyl Grooves */
  .vinyl-record::before {
    content: '';
    position: absolute;
    width: 82%;
    height: 82%;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    pointer-events: none;
  }
  .vinyl-record::after {
    content: '';
    position: absolute;
    width: 64%;
    height: 64%;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    pointer-events: none;
  }

  .vinyl-center {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    overflow: hidden;
    background: #fff;
    border: 2px solid #333;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
  }

  #track-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: counter-spin 8s linear infinite;
    animation-play-state: paused;
    background-color: var(--color-bg-white, #fff);
  }
  
  .vinyl-record.playing #track-cover {
    animation-play-state: running;
  }

  /* --- Player Panel (Swiss Grid Rectangular) --- */
  .player-panel {
    height: 52px;
    width: 0;
    flex-shrink: 0;
    background: var(--color-bg-white, #fff);
    border: 2px solid var(--color-border, #ccc);
    border-left: none; /* Attach seamlessly to vinyl */
    box-shadow: 4px 4px 0px var(--color-border, #ccc);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    opacity: 0;
    transform: translateX(-16px); /* tuck under the vinyl */
    z-index: 1;
    box-sizing: border-box;
  }

  /* Open State */
  .music-widget:hover .player-panel,
  .music-widget.active .player-panel {
    width: 250px; /* Explicit width */
    opacity: 1;
  }

  .player-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px 0 24px; /* extra left padding because tucked under vinyl */
    height: 44px;
    flex-shrink: 0;
  }

  .track-info {
    flex-grow: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #track-name {
    font-weight: 900;
    font-size: 0.85rem;
    color: var(--color-text-primary, #000);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  #track-artist {
    font-size: 0.7rem;
    color: var(--color-text-secondary, #666);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: var(--font-code, monospace);
  }

  .controls {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-shrink: 0;
  }

  .controls button {
    background: none;
    border: none;
    font-size: 1rem;
    color: var(--color-text-primary, #000);
    cursor: pointer;
    padding: 4px;
    transition: transform 0.1s ease, color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .controls button:hover {
    transform: scale(1.1);
    color: var(--color-section-dark-bg, #000);
  }
  .controls button:active {
    transform: scale(0.9);
  }

  /* --- Progress Bar --- */
  .progress-container {
    width: 100%;
    height: 4px;
    background: var(--color-border, #ccc);
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s ease, height 0.2s ease;
  }
  .progress-container:hover {
    opacity: 1;
    height: 6px;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-text-primary, #000);
    transition: width 0.1s linear;
  }

  :global([data-theme="dark"]) .progress-container {
    background: #444;
  }
  :global([data-theme="dark"]) .progress-fill {
    background: #fff;
  }
  :global([data-theme="dark"]) .vinyl-center {
    background: #000;
  }

  /* Keyframes */
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes counter-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const widget = document.getElementById('custom-music-player');
    const dragHandle = document.getElementById('player-drag-handle');
    
    // --- Draggable Logic ---
    let isDragging = false;
    let startX, startY, initialLeft, initialTop;
    let hasDragged = false; // to differentiate click vs drag

    dragHandle.addEventListener('mousedown', (e) => {
      isDragging = true;
      hasDragged = false;
      startX = e.clientX;
      startY = e.clientY;
      
      const rect = widget.getBoundingClientRect();
      widget.style.right = 'auto';
      widget.style.bottom = 'auto';
      widget.style.left = rect.left + 'px';
      widget.style.top = rect.top + 'px';
      
      initialLeft = rect.left;
      initialTop = rect.top;
      
      document.body.style.userSelect = 'none';
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) {
        hasDragged = true;
      }

      widget.style.left = `${initialLeft + dx}px`;
      widget.style.top = `${initialTop + dy}px`;
    });

    window.addEventListener('mouseup', () => {
      if (isDragging && !hasDragged) {
        // Was a click, toggle active state for mobile/touch
        widget.classList.toggle('active');
      }
      isDragging = false;
      document.body.style.userSelect = '';
    });

    // --- Music Fetching & Playback Logic ---
    const audio = document.getElementById('audio-element');
    const btnPlay = document.getElementById('btn-play');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    const trackName = document.getElementById('track-name');
    const trackArtist = document.getElementById('track-artist');
    const trackCover = document.getElementById('track-cover');
    const vinylRecord = document.querySelector('.vinyl-record');
    const progressContainer = document.getElementById('progress-container');
    const progressFill = document.getElementById('progress-fill');

    let playlist = [];
    let currentIndex = 0;
    
    const server = widget.getAttribute('data-server');
    const type = widget.getAttribute('data-type');
    const id = widget.getAttribute('data-id');
    
    // Ensure we have an ID to fetch
    if (!id || id === "undefined" || id === "") {
        trackName.textContent = "No Playlist ID";
        trackArtist.textContent = "Please provide an ID";
        return;
    }

    // Fetch from Meting API
    const apiUrl = `https://api.injahow.cn/meting/?server=${server}&type=${type}&id=${id}&r=${Math.random()}`;
    
    fetch(apiUrl)
      .then(res => res.json())
      .then(data => {
        if (data && data.length > 0) {
          playlist = data;
          loadTrack(currentIndex);
        } else {
          trackName.textContent = "No tracks found";
          trackArtist.textContent = "Check API or ID";
        }
      })
      .catch(err => {
        console.error('Music Fetch Error:', err);
        trackName.textContent = "API Error";
        trackArtist.textContent = "Failed to load playlist";
      });

    function loadTrack(index) {
      if (!playlist[index]) return;
      const track = playlist[index];
      audio.src = track.url;
      trackName.textContent = track.name || 'Unknown Title';
      trackArtist.textContent = track.artist || 'Unknown Artist';
      if (track.pic) {
        trackCover.src = track.pic;
      }
      
      if (btnPlay.textContent === '⏸') {
        audio.play().catch(() => {
           btnPlay.textContent = '▶';
           vinylRecord.classList.remove('playing');
        });
      }
    }

    function togglePlay() {
      if (playlist.length === 0) return;
      if (audio.paused) {
        audio.play();
        btnPlay.textContent = '⏸';
        vinylRecord.classList.add('playing');
      } else {
        audio.pause();
        btnPlay.textContent = '▶';
        vinylRecord.classList.remove('playing');
      }
    }

    function playNext() {
      if (playlist.length === 0) return;
      currentIndex = (currentIndex + 1) % playlist.length;
      loadTrack(currentIndex);
      audio.play();
      btnPlay.textContent = '⏸';
      vinylRecord.classList.add('playing');
    }

    function playPrev() {
      if (playlist.length === 0) return;
      currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
      loadTrack(currentIndex);
      audio.play();
      btnPlay.textContent = '⏸';
      vinylRecord.classList.add('playing');
    }

    btnPlay.addEventListener('click', togglePlay);
    btnNext.addEventListener('click', playNext);
    btnPrev.addEventListener('click', playPrev);

    audio.addEventListener('ended', playNext);

    audio.addEventListener('timeupdate', () => {
      if (audio.duration) {
        const percent = (audio.currentTime / audio.duration) * 100;
        progressFill.style.width = `${percent}%`;
      }
    });

    progressContainer.addEventListener('click', (e) => {
      if (audio.duration) {
        const rect = progressContainer.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const percent = clickX / rect.width;
        audio.currentTime = percent * audio.duration;
      }
    });
  });
</script>